<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Shop-o-matic</title>
  <%= csrf_meta_tags %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body { background: #f4f5f7; }
    .sidebar { width: 220px; min-height: 100vh; background: #1c1c2e; flex-shrink: 0; position: sticky; top: 0; }
    .sidebar .brand { padding: 1.5rem 1.25rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.08); }
    .sidebar .brand h6 { color: #fff; font-weight: 700; margin: 0; letter-spacing: -0.3px; }
    .sidebar .brand small { color: rgba(255,255,255,0.35); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .sidebar .nav-link { color: rgba(255,255,255,0.6); padding: 0.55rem 1.25rem; font-size: 0.875rem; border-radius: 0; transition: none; }
    .sidebar .nav-link:hover { color: #fff; background: rgba(255,255,255,0.07); }
    .sidebar .nav-link.active { color: #fff; background: rgba(255,255,255,0.12); font-weight: 500; }
    .sidebar .nav-link i { width: 1.1rem; margin-right: 0.5rem; }
    .main { flex: 1; min-width: 0; }
    .topbar { background: #fff; border-bottom: 1px solid #e9ecef; padding: 0.75rem 2rem; }
    .content { padding: 2rem; }
    .page-title { font-size: 1.4rem; font-weight: 700; color: #1c1c2e; margin: 0; }
    .table th { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; color: #6c757d; }
    .card { border: 1px solid #e9ecef; }
  </style>
</head>
<body>
<div class="d-flex" style="min-height: 100vh;">
  <aside class="sidebar">
    <div class="brand">
      <h6>Shop-o-matic</h6>
      <small>Admin Portal</small>
    </div>
    <nav class="nav flex-column py-2">
      <%= link_to admin_users_path,
            class: "nav-link #{'active' if controller_name == 'users'}" do %>
        <i class="bi bi-people-fill"></i>Users
      <% end %>
      <%= link_to admin_households_path,
            class: "nav-link #{'active' if controller_name == 'households'}" do %>
        <i class="bi bi-house-fill"></i>Households
      <% end %>
    </nav>
  </aside>

  <div class="main">
    <div class="topbar d-flex align-items-center">
      <p class="page-title"><%= content_for?(:page_title) ? yield(:page_title) : "Admin" %></p>
      <div class="ms-auto d-flex align-items-center gap-3">
        <% if content_for?(:header_actions) %>
          <%= yield(:header_actions) %>
        <% end %>
        <% if current_admin_user %>
          <span class="text-muted small"><%= current_admin_user.name %></span>
          <%= button_to "Sign out", admin_logout_path, method: :delete,
                class: "btn btn-sm btn-outline-secondary" %>
        <% end %>
      </div>
    </div>

    <div class="content">
      <% flash.each do |type, message| %>
        <% bs_type = type.to_s == "notice" ? "success" : "danger" %>
        <div class="alert alert-<%= bs_type %> alert-dismissible fade show" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <%= yield %>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
