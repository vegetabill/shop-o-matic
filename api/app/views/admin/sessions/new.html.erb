<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Sign In — Shop-o-matic</title>
  <%= csrf_meta_tags %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: #f4f5f7; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .login-card { width: 100%; max-width: 360px; }
    .brand { font-weight: 700; color: #1c1c2e; font-size: 1.1rem; }
    .brand small { display: block; color: #6c757d; font-weight: 400; font-size: 0.8rem; }
  </style>
</head>
<body>
<div class="login-card p-4">
  <div class="text-center mb-4">
    <p class="brand">Shop-o-matic<small>Admin Portal</small></p>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-body p-4">
      <% flash.each do |type, message| %>
        <div class="alert alert-<%= type.to_s == 'notice' ? 'success' : 'danger' %> py-2 small mb-3">
          <%= message %>
        </div>
      <% end %>

      <%= link_to "Sign in with Auth0", admin_auth_start_path, class: "btn btn-primary w-100" %>
    </div>
  </div>
</div>
</body>
</html>
