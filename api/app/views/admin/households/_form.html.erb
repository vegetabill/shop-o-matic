<%= form_with model: [:admin, household] do |f| %>
  <% if household.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0 ps-3">
        <% household.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, class: "form-label fw-medium" %>
    <%= f.text_field :name, class: "form-control", required: true, autofocus: true %>
    <% if household.new_record? %>
      <div class="form-text">A share token and default store/categories will be created automatically.</div>
    <% end %>
  </div>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit household.new_record? ? "Create Household" : "Save Changes", class: "btn btn-primary" %>
    <%= link_to "Cancel",
          household.new_record? ? admin_households_path : admin_household_path(household),
          class: "btn btn-outline-secondary" %>
  </div>
<% end %>
