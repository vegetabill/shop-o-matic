<% content_for :page_title, "Households" %>
<% content_for :header_actions do %>
  <%= link_to "New Household", new_admin_household_path, class: "btn btn-primary btn-sm" %>
<% end %>

<div class="card shadow-none">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Name</th>
          <th>Share Token</th>
          <th>Members</th>
          <th>Items</th>
          <th>Stores</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @households.each do |hh| %>
          <tr>
            <td><%= link_to hh.name, admin_household_path(hh), class: "fw-medium text-decoration-none text-dark" %></td>
            <td><code class="small text-muted"><%= hh.share_token %></code></td>
            <td><span class="badge bg-secondary rounded-pill"><%= hh.users.size %></span></td>
            <td class="text-muted small"><%= hh.items.count %></td>
            <td class="text-muted small"><%= hh.stores.count %></td>
            <td class="text-muted small"><%= hh.created_at.strftime("%b %-d, %Y") %></td>
            <td class="text-end">
              <%= link_to "Edit", edit_admin_household_path(hh), class: "btn btn-sm btn-outline-secondary me-1" %>
              <%= button_to "Delete", admin_household_path(hh), method: :delete,
                    class: "btn btn-sm btn-outline-danger",
                    form: { onsubmit: "return confirm('Delete #{hh.name}? All data will be lost.')" } %>
            </td>
          </tr>
        <% end %>
        <% if @households.empty? %>
          <tr><td colspan="7" class="text-center text-muted py-4">No households yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<p class="text-muted small mt-2"><%= pluralize(@households.count, "household") %></p>
