<% content_for :page_title, @user.name %>
<% content_for :header_actions do %>
  <%= link_to "Edit", edit_admin_user_path(@user), class: "btn btn-outline-secondary btn-sm me-2" %>
  <%= button_to "Delete", admin_user_path(@user), method: :delete,
        class: "btn btn-outline-danger btn-sm",
        form: { onsubmit: "return confirm('Delete #{@user.name}? This cannot be undone.')" } %>
<% end %>

<div class="row g-3">
  <div class="col-md-4">
    <div class="card shadow-none h-100">
      <div class="card-body">
        <h6 class="text-uppercase text-muted small fw-semibold mb-3">User Details</h6>
        <dl class="row mb-0">
          <dt class="col-sm-4 text-muted small">ID</dt>
          <dd class="col-sm-8 small"><%= @user.id %></dd>

          <dt class="col-sm-4 text-muted small">Name</dt>
          <dd class="col-sm-8"><%= @user.name %></dd>

          <dt class="col-sm-4 text-muted small">Email</dt>
          <dd class="col-sm-8"><%= @user.email %></dd>

          <dt class="col-sm-4 text-muted small">Auth UID</dt>
          <dd class="col-sm-8"><code class="small"><%= @user.auth0_uid %></code></dd>

          <dt class="col-sm-4 text-muted small">Joined</dt>
          <dd class="col-sm-8 small"><%= @user.created_at.strftime("%b %-d, %Y %H:%M UTC") %></dd>
        </dl>
      </div>
    </div>
  </div>

  <div class="col-md-8">
    <div class="card shadow-none">
      <div class="card-body">
        <h6 class="text-uppercase text-muted small fw-semibold mb-3">
          Households (<%= @user.households.count %>)
        </h6>
        <% if @user.households.any? %>
          <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Name</th>
                <th>Share Token</th>
                <th>Members</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @user.households.order(:name).each do |hh| %>
                <tr>
                  <td><%= link_to hh.name, admin_household_path(hh), class: "text-decoration-none" %></td>
                  <td><code class="small"><%= hh.share_token %></code></td>
                  <td><%= hh.users.count %></td>
                  <td class="text-end">
                    <%= link_to "View", admin_household_path(hh), class: "btn btn-sm btn-outline-secondary" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <p class="text-muted small mb-0">Not a member of any household.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
