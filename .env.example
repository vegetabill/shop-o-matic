# Copy to .env and fill in your values

# Postgres connection (defaults shown)
# POSTGRES_USER=shopomatic
# POSTGRES_DB=shop_o_matic_production

# Rails secret key base (generate with: openssl rand -hex 64)
SECRET_KEY_BASE=change-me-in-production

# JWT signing key
JWT_SECRET=change-me-in-production

# Auth0 settings (from your Auth0 application)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=your-auth0-client-id

# API base URL baked into the Expo web build at Docker build time.
# Default is /api/v1 (same-origin). Override if your API is on a separate host.
# EXPO_PUBLIC_API_BASE_URL=/api/v1

# Expo Go QR code URL (set to your EAS published URL after running `eas update`)
# EXPO_APP_URL=exp://u.expo.dev/20a706e9-ac86-4193-a6ba-f09be69ec3ec?channel-name=production

# MQTT integration (optional — omit MQTT_HOST to disable)
# MQTT_HOST=your-broker.local
# MQTT_PORT=1883
# MQTT_TOPIC=homeassistant/shopping_list
# MQTT_USERNAME=shopomatic
# MQTT_PASSWORD=your-password

# Optional overrides
PORT=8080
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2
