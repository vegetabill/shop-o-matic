{
  "expo": {
    "name": "Shop-o-matic",
    "slug": "shop-o-matic",
    "scheme": "shopomaticapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2F2F7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.29poms.shop",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is not used by this app.",
        "NSPhotoLibraryUsageDescription": "Photo library is not used by this app.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F2F2F7"
      },
      "package": "com.29poms.shop"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "20a706e9-ac86-4193-a6ba-f09be69ec3ec"
      }
    },
    "owner": "immutabill",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/20a706e9-ac86-4193-a6ba-f09be69ec3ec"
    }
  }
}